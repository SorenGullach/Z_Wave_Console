<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Vibrant Color Palette (Colors) -->
    <Color x:Key="AccentBlueColor">#1E88E5</Color>
    <Color x:Key="AccentCyanColor">#00BCD4</Color>
    <Color x:Key="AccentOrangeColor">#FF9800</Color>

    <!-- Node State Colors -->
    <SolidColorBrush x:Key="NodeInterviewPendingBrush" Color="#E53935"/>    <!-- Red -->
    <SolidColorBrush x:Key="NodeAwakeBrush" Color="#4CAF50"/>    <!-- Green -->
    <SolidColorBrush x:Key="NodeSleepyBrush" Color="#FFC107"/>    <!-- Amber -->
    <SolidColorBrush x:Key="NodeDeadBrush" Color="#E53935"/>    <!-- Red -->
    <SolidColorBrush x:Key="NodeDefaultBrush" Color="#263238"/>    <!-- Dark text -->

    <!-- Brushes (use these for BorderBrush / Foreground / Background setters) -->
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlueColor}" />
    <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource AccentCyanColor}" />
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrangeColor}" />

    <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBorder" Color="#D0D7E2"/>
    <SolidColorBrush x:Key="TagBackground" Color="#E3F2FD"/>
    <SolidColorBrush x:Key="TagBorder" Color="#90CAF9"/>

    <!-- Global Text Style -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="#263238"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- Vibrant GroupBox -->
    <Style TargetType="GroupBox">
        <Setter Property="Margin" Value="0,0,8,12"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
        <Setter Property="BorderThickness" Value="4"/>
        <Setter Property="Background" Value="{StaticResource CardBackground}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid>
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15"/>
                            </Border.Effect>
                        </Border>

                        <StackPanel>
                            <!-- Vibrant Header -->
                            <Border Padding="8"
                                    CornerRadius="6,6,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="{StaticResource AccentBlueColor}" Offset="0"/>
                                        <GradientStop Color="{StaticResource AccentCyanColor}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="{TemplateBinding Header}"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="14"/>
                            </Border>

                            <ContentPresenter Margin="12"/>
                        </StackPanel>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Vibrant Tag Style -->
    <Style x:Key="TagStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource TagBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource TagBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Highlighted Values -->
    <Style x:Key="ValueHighlight" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <SolidColorBrush x:Key="SomeBorderBrush" Color="#FFD0D7E2" />

    <Style TargetType="Button">
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1E88E5" Offset="0"/>
                    <GradientStop Color="#00BCD4" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.25"/>
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                        CornerRadius="4"
                        SnapsToDevicePixels="True"
                        Padding="4,4,4,4">
                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      RecognizesAccessKey="True"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>

            <!-- PRESSED -->
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1565C0" Offset="0"/>
                            <GradientStop Color="#0097A7" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.15"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Padding" Value="9,5"/>
            </Trigger>

            <!-- DISABLED -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#B0BEC5"/>
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#CFD8DC" Offset="0"/>
                            <GradientStop Color="#B0BEC5" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Cursor" Value="Arrow"/>
            </Trigger>

        </Style.Triggers>
    </Style>

    <!-- Vibrant Checkbox -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="#263238"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,4,12,0"/>
    </Style>

    <!-- Level Tag Style -->
    <Style x:Key="LevelTagStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="Background" Value="#E3F2FD"/>
        <Setter Property="BorderBrush" Value="#64B5F6"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DataGrid Vibrant Theme -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#D0D7E2"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="RowBackground" Value="#FAFAFA"/>
        <Setter Property="AlternatingRowBackground" Value="#F0F4F8"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#CFD8DC"/>
        <Setter Property="VerticalGridLinesBrush" Value="#CFD8DC"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Header Style -->
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1E88E5" Offset="0"/>
                    <GradientStop Color="#00BCD4" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="6"/>
    </Style>

    <!-- Log Level Coloring -->
    <Style TargetType="TextBlock" x:Key="LevelColorizer">
        <Style.Triggers>
            <DataTrigger Binding="{Binding Level}" Value="ERR">
                <Setter Property="Foreground" Value="#E53935"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Level}" Value="WRN">
                <Setter Property="Foreground" Value="#FB8C00"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Level}" Value="INF">
                <Setter Property="Foreground" Value="#1E88E5"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Level}" Value="DBG">
                <Setter Property="Foreground" Value="#6B7A89"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Hexadecimal input filter -->
    <Style x:Key="HexTextBox" TargetType="TextBox"/>

</ResourceDictionary>
    
