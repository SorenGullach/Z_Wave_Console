<Window x:Class="Z_Wave_UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:Z_Wave_UI.Helpers"
        xmlns:local="clr-namespace:Z_Wave_UI"
        mc:Ignorable="d"
        Title="MainWindow" Height="auto" Width="auto" MinHeight="600" MinWidth="800">
    <Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

        <TabControl Grid.Row="0" >
            <TabItem Header="Module info" DataContext="{Binding ModuleInfo}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <GroupBox Header="Status" Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                            <StackPanel Margin="8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Initialization:" Width="120" />
                                    <TextBlock Text="{Binding InitializationState}" />
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="API" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Version:" Width="120" />
                                    <TextBlock Text="{Binding ApiVersion}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Capabilities:" Width="120" />
                                    <TextBlock Text="{Binding ApiCapabilities}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Capabilities Desc:" Width="120" />
                                    <TextBlock Text="{Binding ApiCapabilitiesDescription}" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Network" Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                            <StackPanel Margin="8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="HomeId:" Width="120" />
                                    <TextBlock Text="{Binding HomeIdHex}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="NodeId:" Width="120" />
                                    <TextBlock Text="{Binding NodeId}" />
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Library / App" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Library Version:" Width="120" />
                                    <TextBlock Text="{Binding LibraryVersion}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Library Type:" Width="120" />
                                    <TextBlock Text="{Binding LibraryType}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Library Type Name:" Width="120" />
                                    <TextBlock Text="{Binding LibraryTypeName}" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="App Version:" Width="120" />
                                    <TextBlock Text="{Binding AppVersion}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="App Revision:" Width="120" />
                                    <TextBlock Text="{Binding AppRevision}" />
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Node Ids" Grid.Row="2" Grid.Column="0" Margin="0,0,8,8">
                            <ItemsControl ItemsSource="{Binding NodeIds}" Margin="8">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#EEEEEE" CornerRadius="2" Padding="4" Margin="2">
                                            <TextBlock Text="{Binding}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <GroupBox Header="API Commands" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                            <ItemsControl ItemsSource="{Binding ApiCommands}" Margin="8">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#EEEEEE" CornerRadius="2" Padding="4" Margin="2">
                                            <TextBlock Text="{Binding}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <GroupBox Header="Controller Flags" Grid.Row="3" Grid.Column="0" Margin="0,0,8,0">
                            <ItemsControl ItemsSource="{Binding ControllerFlags}" Margin="8">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#EEEEEE" CornerRadius="2" Padding="4" Margin="2">
                                            <TextBlock Text="{Binding}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <StackPanel Grid.Row="3" Grid.Column="1">
                            <GroupBox Header="Chip" Margin="0,0,0,8">
                                <ItemsControl ItemsSource="{Binding Chip}" Margin="8">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#EEEEEE" CornerRadius="2" Padding="4" Margin="2">
                                                <TextBlock Text="{Binding}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </GroupBox>

                            <GroupBox Header="Protocol Version" Margin="0,0,0,8">
                                <ItemsControl ItemsSource="{Binding ProtocolVersion}" Margin="8">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#EEEEEE" CornerRadius="2" Padding="4" Margin="2">
                                                <TextBlock Text="{Binding}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </GroupBox>

                            <GroupBox Header="Manufacturer">
                                <ItemsControl ItemsSource="{Binding Manufacturer}" Margin="8">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#EEEEEE" CornerRadius="2" Padding="4" Margin="2">
                                                <TextBlock Text="{Binding}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </GroupBox>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Logging" DataContext="{Binding Logging}">
                <Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>

					<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,0">
						<Button Content="Copy" MinWidth ="50" Margin="10,3,10,3" Command="{Binding CopyLogsCommand}" />
                        <TextBlock Text="Levels:" VerticalAlignment="Center" Margin="0,0,6,0" />
						<ItemsControl ItemsSource="{Binding LevelFilters}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<CheckBox Content="{Binding Level}"
											  IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
											  Margin="0,5,12,0" />
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>

                    <DataGrid Grid.Row="1"
					  ItemsSource="{Binding LogsView}"
					  helpers:DataGridAutoScrollBehavior.AutoScrollToEnd="True"
					  IsReadOnly="True"
					  AutoGenerateColumns="False"
					  HeadersVisibility="Column"
					  CanUserAddRows="False"
					  CanUserDeleteRows="False"
					  Margin="8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Width="80" Binding="{Binding DisplayTime}" />
                            <DataGridTextColumn Header="Level" Width="60" Binding="{Binding Level}" />
                            <DataGridTextColumn Header="Tag" Width="200" Binding="{Binding Tag}" />
                            <DataGridTextColumn Header="Message" Width="*" Binding="{Binding Message}" />
                        </DataGrid.Columns>
                    </DataGrid>
				</Grid>
            </TabItem>
        </TabControl>
        <Border Grid.Row="1" Padding="8" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" DataContext="{Binding Connection}">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="Host:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Width="160" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Port:" VerticalAlignment="Center" Margin="12,0,6,0" />
                    <TextBox Width="70" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="Connect" Command="{Binding ConnectCommand}" Margin="0,0,8,0" />
                    <Button Content="Disconnect" Command="{Binding DisconnectCommand}" Margin="0,0,8,0" />
                    <Button Content="Refresh Logs" Command="{Binding RefreshLogsCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>
        <TextBlock Grid.Row="2"
				   Text="{Binding StatusMessage}"
				   Margin="8"
				   Foreground="Gray"
				   HorizontalAlignment="Left" />

    </Grid>
</Window>
