<UserControl x:Class="Z_Wave_UI.LoggingTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:Z_Wave_UI.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Z_Wave_UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Dictionary1.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid Background="#F5F7FA">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,12,12,4">
                <Button Content="Copy" MinWidth="70" Command="{Binding CopyLogsCommand}" />

                <TextBlock Text="Levels:" VerticalAlignment="Center" Margin="16,0,6,0" 
                       Foreground="#263238" FontWeight="Bold"/>

                <ItemsControl ItemsSource="{Binding LevelFilters}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource LevelTagStyle}">
                                <CheckBox Content="{Binding Level}"
                                      IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Foreground="#263238"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- DataGrid -->
            <DataGrid Grid.Row="1"
                  ItemsSource="{Binding LogsView}"
                  helpers:DataGridAutoScrollBehavior.AutoScrollToEnd="True"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  Margin="12">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time" Width="80" Binding="{Binding DisplayTime}" />

                    <DataGridTextColumn Header="Level" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource LevelColorizer}">
                                <Setter Property="Text" Value="{Binding Level}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Tag" Width="200" Binding="{Binding Tag}" />
                    <DataGridTextColumn Header="Message" Width="*" Binding="{Binding Message}" />
                </DataGrid.Columns>

            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
