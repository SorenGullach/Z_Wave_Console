<UserControl x:Class="Z_Wave_UI.NodesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Z_Wave_UI"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:viewmodels="clr-namespace:Z_Wave_UI.ViewModels"
             xmlns:models="clr-namespace:Z_Wave_UI.Models"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Dictionary1.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <!-- TreeView column -->
            <ColumnDefinition Width="250" MinWidth="150"/>
            <!-- Splitter -->
            <ColumnDefinition Width="5"/>
            <!-- Right panel -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TreeView Margin="6"
                  Grid.Column="0"
                  ItemsSource="{Binding NodeList.Tree}"
                  SelectedItemChanged="TreeView_SelectedItemChanged">
            <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type viewmodels:FloorGroup}" ItemsSource="{Binding Rooms}">
                    <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                </HierarchicalDataTemplate>
                <HierarchicalDataTemplate DataType="{x:Type viewmodels:RoomGroup}" ItemsSource="{Binding Nodes}">
                    <TextBlock Text="{Binding Name}" />
                </HierarchicalDataTemplate>
                <DataTemplate DataType="{x:Type models:NodeListInfo}">
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock x:Name="NodeIdText"
                                   Margin="0,0,6,0"
                                   FontWeight="Bold"
                                   Text="{Binding NodeId}"/>

                        <TextBlock x:Name="StateText"
                                   Margin="0,0,6,0"
                                   Text="{Binding State}"/>

                        <TextBlock x:Name="InterviewText"
                                   Foreground="Gray"
                                   Text="{Binding InterviewState}"/>
                    </StackPanel>

                    <DataTemplate.Triggers>

                        <!-- DEAD always wins -->
                        <DataTrigger Binding="{Binding State}" Value="Dead">
                            <Setter TargetName="NodeIdText"
                                    Property="Foreground"
                                    Value="{StaticResource NodeDeadBrush}"/>
                            <Setter TargetName="StateText"
                                    Property="Foreground"
                                    Value="{StaticResource NodeDeadBrush}"/>
                            <Setter TargetName="InterviewText"
                                    Property="Foreground"
                                    Value="{StaticResource NodeDeadBrush}"/>
                        </DataTrigger>

                        <!-- INTERVIEW NOT DONE (red) -->
                        <DataTrigger Binding="{Binding InterviewState}" Value="InterviewDone">
                            <!-- Do nothing here -->
                        </DataTrigger>

                        <DataTrigger Binding="{Binding InterviewState}" Value="{x:Null}">
                            <Setter TargetName="NodeIdText"
                                    Property="Foreground"
                                    Value="{StaticResource NodeInterviewPendingBrush}"/>
                            <Setter TargetName="StateText"
                                    Property="Foreground"
                                    Value="{StaticResource NodeInterviewPendingBrush}"/>
                            <Setter TargetName="InterviewText"
                                    Property="Foreground"
                                    Value="{StaticResource NodeInterviewPendingBrush}"/>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding InterviewState}" Value="">
                            <Setter TargetName="NodeIdText"
                                    Property="Foreground"
                                    Value="{StaticResource NodeInterviewPendingBrush}"/>
                            <Setter TargetName="StateText"
                                    Property="Foreground"
                                    Value="{StaticResource NodeInterviewPendingBrush}"/>
                            <Setter TargetName="InterviewText"
                                    Property="Foreground"
                                    Value="{StaticResource NodeInterviewPendingBrush}"/>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding InterviewState}" Value="ProtocolInfoDone">
                            <Setter TargetName="NodeIdText"
                                    Property="Foreground"
                                    Value="{StaticResource NodeInterviewPendingBrush}"/>
                            <Setter TargetName="StateText"
                                    Property="Foreground"
                                    Value="{StaticResource NodeInterviewPendingBrush}"/>
                            <Setter TargetName="InterviewText"
                                    Property="Foreground"
                                    Value="{StaticResource NodeInterviewPendingBrush}"/>
                        </DataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding State}" Value="Sleepy"/>
                                <Condition Binding="{Binding InterviewState}" Value="InterviewDone"/>
                                <Condition Binding="{Binding NeedsUpdate}" Value="True"/>
                            </MultiDataTrigger.Conditions>

                            <!-- Background highlight, keep original text color -->
                            <Setter TargetName="NodeIdText"
                                Property="Background"
                                Value="{StaticResource NodeNeedsUpdateBrush}"/>

                            <Setter TargetName="StateText"
                                Property="Background"
                                Value="{StaticResource NodeNeedsUpdateBrush}"/>

                            <Setter TargetName="InterviewText"
                                Property="Background"
                                Value="{StaticResource NodeNeedsUpdateBrush}"/>
                        </MultiDataTrigger>

                        <!-- AWAKE -->
                        <DataTrigger Binding="{Binding State}" Value="Awake">
                            <Setter TargetName="NodeIdText"
                                    Property="Foreground"
                                    Value="{StaticResource NodeAwakeBrush}"/>
                            <Setter TargetName="StateText"
                                    Property="Foreground"
                                    Value="{StaticResource NodeAwakeBrush}"/>
                        </DataTrigger>

                        <!-- SLEEPY -->
                        <DataTrigger Binding="{Binding State}" Value="Sleepy">
                            <Setter TargetName="NodeIdText"
                                    Property="Foreground"
                                    Value="{StaticResource NodeSleepyBrush}"/>
                            <Setter TargetName="StateText"
                                    Property="Foreground"
                                    Value="{StaticResource NodeSleepyBrush}"/>
                        </DataTrigger>

                    </DataTemplate.Triggers>
                </DataTemplate>
            </TreeView.Resources>
        </TreeView>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#DDD"
                      ShowsPreview="True"/>

        <ScrollViewer Grid.Column="2"
                      VerticalScrollBarVisibility="Auto"
                      DataContext="{Binding NodeInfo.Node}">

            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- BASIC INFO -->
                <GroupBox Header="Basic Information" Grid.Row="0" Grid.Column="0">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Node ID:" Grid.Row="0" Grid.Column="0"/>
                        <TextBlock Text="{Binding NodeId}" Grid.Row="0" Grid.Column="1"/>

                        <TextBlock Text="Floor:" Grid.Row="1" Grid.Column="0"/>
                        <TextBlock Text="{Binding Floor}" Grid.Row="1" Grid.Column="1"/>

                        <TextBlock Text="Room:" Grid.Row="2" Grid.Column="0"/>
                        <TextBlock Text="{Binding Room}" Grid.Row="2" Grid.Column="1"/>

                        <TextBlock Text="State:" Grid.Row="3" Grid.Column="0"/>
                        <TextBlock Text="{Binding State}" Grid.Row="3" Grid.Column="1"/>

                        <TextBlock Text="Interview State:" Grid.Row="4" Grid.Column="0"/>
                        <TextBlock Text="{Binding InterviewState}" Grid.Row="4" Grid.Column="1"/>
                    </Grid>
                </GroupBox>

                <!-- PROTOCOL INFO -->
                <GroupBox Header="Protocol Information" Grid.Row="0" Grid.Column="1">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Basic:" Grid.Row="0" Grid.Column="0"/>
                        <TextBlock Text="{Binding Protocol.Basic}" Grid.Row="0" Grid.Column="1"/>

                        <TextBlock Text="Generic:" Grid.Row="1" Grid.Column="0"/>
                        <TextBlock Text="{Binding Protocol.Generic}" Grid.Row="1" Grid.Column="1"/>

                        <TextBlock Text="Specific:" Grid.Row="2" Grid.Column="0"/>
                        <TextBlock Text="{Binding Protocol.Specific}" Grid.Row="2" Grid.Column="1"/>

                        <TextBlock Text="Listening:" Grid.Row="3" Grid.Column="0"/>
                        <TextBlock Text="{Binding Protocol.Listening}" Grid.Row="3" Grid.Column="1"/>

                        <TextBlock Text="Routing:" Grid.Row="4" Grid.Column="0"/>
                        <TextBlock Text="{Binding Protocol.Routing}" Grid.Row="4" Grid.Column="1"/>

                        <TextBlock Text="Speed:" Grid.Row="5" Grid.Column="0"/>
                        <TextBlock Text="{Binding Protocol.Speed}" Grid.Row="5" Grid.Column="1"/>

                        <TextBlock Text="Protocol Version:" Grid.Row="6" Grid.Column="0"/>
                        <TextBlock Text="{Binding Protocol.ProtocolVersion}" Grid.Row="6" Grid.Column="1"/>
                    </Grid>
                </GroupBox>

                <!-- SUPPORTED CCs -->
                <GroupBox Header="Supported Command Classes" Grid.Row="1" Grid.Column="0">
                    <ItemsControl ItemsSource="{Binding SupportedCCs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding cc, StringFormat=0x{0:X2}}" Width="60"/>
                                    <TextBlock Text="{Binding Name}" Grid.Column="1"/>
                                    <TextBlock Text="{Binding Version}" Grid.Column="2"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>

                <!-- MULTI CHANNEL -->
                <GroupBox Header="Multi-Channel Endpoints" Grid.Row="1" Grid.Column="1">
                    <ItemsControl ItemsSource="{Binding MultiChannel.Endpoints}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="Endpoint:" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding EndpointId}"/>

                                    <TextBlock Text="Generic:"/>
                                    <TextBlock Text="{Binding Generic}"/>

                                    <TextBlock Text="Specific:"/>
                                    <TextBlock Text="{Binding Specific}"/>

                                    <TextBlock Text="Supported CCs:"/>
                                    <ItemsControl ItemsSource="{Binding SupportedCCs}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Margin="2"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>

                <!-- MULTICHANNEL ASSOCIATIONS -->
                <GroupBox Header="Associations" Grid.Row="2" Grid.Column="0">
                    <StackPanel Margin="4">

                        <!-- Add/remove multi-channel association -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,8"
                                    VerticalAlignment="Center">

                            <TextBlock Margin="0,0,4,0"
                                       VerticalAlignment="Center"
                                       Text="Group:"/>
                            <TextBox Width="40"
                                     Margin="0,0,12,0"
                                     Text="{Binding DataContext.NodeInfo.NewAssocGroup, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Margin="0,0,4,0"
                                       VerticalAlignment="Center"
                                       Text="Node:"/>
                            <TextBox Width="40"
                                     Margin="0,0,12,0"
                                     Text="{Binding DataContext.NodeInfo.NewAssocNode, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Margin="0,0,4,0"
                                       VerticalAlignment="Center"
                                       Text="EP:"/>
                            <TextBox Width="40"
                                     Margin="0,0,12,0"
                                     Text="{Binding DataContext.NodeInfo.NewAssocEndpoint, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"/>

                            <Button Margin="0,0,8,0"
                                    Command="{Binding DataContext.NodeInfo.AddMultiChannelAssociationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Content="Add"/>

                            <Button Margin="0,0,8,0"
                                    Command="{Binding DataContext.NodeInfo.RemoveMultiChannelAssociationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Content="Remove"/>

                            <Button Margin="0,0,8,0"
                                    Command="{Binding DataContext.NodeInfo.UpdateMultiChannelAssociationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Content="Read"/>
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="600">
                            <ItemsControl ItemsSource="{Binding MultiChannelAssociations}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="{Binding GroupId, StringFormat=Group {0}}" 
                                           FontWeight="Bold"/>

                                            <TextBlock Text="Members:"/>

                                            <ItemsControl ItemsSource="{Binding Members}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Margin="2">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text">
                                                                        <Setter.Value>
                                                                            <MultiBinding StringFormat="MC {0}.{1}">
                                                                                <Binding Path="NodeId"/>
                                                                                <Binding Path="Endpoint"/>
                                                                            </MultiBinding>
                                                                        </Setter.Value>
                                                                    </Setter>

                                                                    <!-- If endpoint == 0 → SC instead of MC -->
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Endpoint}" Value="0">
                                                                            <Setter Property="Text">
                                                                                <Setter.Value>
                                                                                    <MultiBinding StringFormat="SC {0}.0">
                                                                                        <Binding Path="NodeId"/>
                                                                                    </MultiBinding>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </GroupBox>

                <!-- CONFIGURATION -->
                <GroupBox Header="Configuration Parameters" Grid.Row="2" Grid.Column="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Height="600">

                        <ItemsControl ItemsSource="{Binding Configuration}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Parameter number -->
                                        <TextBlock Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding Param, StringFormat=Parameter {0} }"/>

                                        <!-- Hex value editor -->
                                        <TextBox Grid.Column="1"
                                                 Margin="4,0"
                                                 VerticalAlignment="Center"
                                                 IsEnabled="{Binding Valid}"
                                                 Style="{StaticResource HexTextBox}"
                                                 Text="{Binding HexValue, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>

                                        <!-- Value size in bytes -->
                                        <ComboBox Grid.Column="2"
                                                  Margin="4,0"
                                                  VerticalAlignment="Center"
                                                  SelectedItem="{Binding Size, Mode=TwoWay}">
                                            <ComboBox.ItemsSource>
                                                <x:Array Type="{x:Type sys:Int32}">
                                                    <sys:Int32>1</sys:Int32>
                                                    <sys:Int32>2</sys:Int32>
                                                    <sys:Int32>4</sys:Int32>
                                                </x:Array>
                                            </ComboBox.ItemsSource>
                                        </ComboBox>

                                        <!-- Sends the edited configuration value -->
                                        <Button Grid.Column="3"
                                                Margin="4,0"
                                                Command="{Binding DataContext.NodeInfo.UpdateConfigCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                IsEnabled="{Binding Valid}"
                                                CommandParameter="{Binding}"
                                                Content="Write"/>
                                        <Button Grid.Column="4"
                                                Margin="4,0"
                                                Command="{Binding DataContext.NodeInfo.UpdateConfigurationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="Read"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </GroupBox>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
